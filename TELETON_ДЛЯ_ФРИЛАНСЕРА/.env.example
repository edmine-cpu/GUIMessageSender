# ─── Telegram API credentials ────────────────────────────────────────────
# Твои личные api_id/api_hash с https://my.telegram.org
# Используются для phone-login сессий и как fallback для аккаунтов
# без прописанных api_id в БД.
OWN_API_ID=12345678
OWN_API_HASH=your_api_hash_here

# Desktop api_id/api_hash зашиты в config.py (DESKTOP_API_ID = 2040).
# Используются ТОЛЬКО для импорта TData через opentele — не трогать.

# ─── Пути ─────────────────────────────────────────────────────────────────
DB_PATH=data/teleton.db
SESSIONS_DIR=data/sessions

# ─── AI providers ─────────────────────────────────────────────────────────
# OpenAI (для smart-parse и уникализации текста)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_PROXY=

# Groq (альтернатива OpenAI для адаптации объявлений)
GROQ_API_KEY=
GROQ_PROXY=
